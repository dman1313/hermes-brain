{
  "alwaysUpdateLinks": true,
  "attachmentFolderPath": "raw/assets",
  "newFileLocation": "folder",
  "newFileFolderPath": "concepts",
  "useMarkdownLinks": false,
  "newLinkFormat": "shortest",
  "userIgnoreFilters": [
    "raw/assets/",
    "_archive/",
    "_meta/",
